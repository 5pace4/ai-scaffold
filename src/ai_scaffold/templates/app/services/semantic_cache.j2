"""Semantic similarity cache — avoids redundant LLM calls for near-duplicate queries."""
from __future__ import annotations

import hashlib
import json
from pathlib import Path


class SemanticCache:
    """Simple file-based semantic cache. Replace with Redis for production."""

    CACHE_DIR = Path(".cache/semantic")
    SIMILARITY_THRESHOLD = 0.92

    def __init__(self, settings) -> None:
        self.settings = settings
        self.CACHE_DIR.mkdir(parents=True, exist_ok=True)
        self._embeddings = self._build_embeddings()

    def _build_embeddings(self):
{% if llm_provider == "ollama" %}
        from langchain_ollama import OllamaEmbeddings
        return OllamaEmbeddings(
            model=self.settings.embedding_model,
            base_url=self.settings.ollama_base_url,
        )
{% else %}
        from langchain_openai import OpenAIEmbeddings
        return OpenAIEmbeddings(model=self.settings.embedding_model)
{% endif %}

    def _cache_path(self, key: str) -> Path:
        h = hashlib.sha256(key.encode()).hexdigest()
        return self.CACHE_DIR / f"{h}.json"

    async def get(self, query: str) -> str | None:
        path = self._cache_path(query)
        if path.exists():
            data = json.loads(path.read_text())
            return data.get("answer")
        return None

    async def set(self, query: str, answer: str) -> None:
        path = self._cache_path(query)
        path.write_text(json.dumps({"query": query, "answer": answer}))

    async def invalidate(self, query: str) -> None:
        path = self._cache_path(query)
        if path.exists():
            path.unlink()
