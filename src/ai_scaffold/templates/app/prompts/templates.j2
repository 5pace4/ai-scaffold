"""Versioned, type-specific prompt templates."""
from __future__ import annotations

from dataclasses import dataclass


@dataclass
class PromptTemplate:
    name: str
    version: str
    system: str
    human: str


RAG_ANSWER_V1 = PromptTemplate(
    name="rag_answer",
    version="1.0",
    system=(
        "You are a helpful assistant for {{ project_name }}. "
        "Answer the question using ONLY the provided context. "
        "If the context doesn't contain the answer, say 'I don't have enough information.'\n\n"
        "Context:\n{context}"
    ),
    human="{question}",
)

QUERY_REWRITE_V1 = PromptTemplate(
    name="query_rewrite",
    version="1.0",
    system=(
        "Rewrite the user query to improve retrieval. "
        "Make it more specific and keyword-rich. Return ONLY the rewritten query."
    ),
    human="Original: {query}",
)

DOCUMENT_GRADE_V1 = PromptTemplate(
    name="document_grade",
    version="1.0",
    system=(
        "You are a document relevance grader. "
        "Given a question and a document excerpt, output 'relevant' or 'not_relevant'."
    ),
    human="Question: {question}\nDocument: {document}",
)

ROUTE_CLASSIFY_V1 = PromptTemplate(
    name="route_classify",
    version="1.0",
    system=(
        "Classify the query: rag (needs docs), agent (needs tools), direct (simple answer). "
        "Return ONLY the category."
    ),
    human="{query}",
)
