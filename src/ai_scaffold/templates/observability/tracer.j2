"""Per-stage tracing for the RAG/agent pipeline."""
from __future__ import annotations

import time
import uuid
from contextlib import contextmanager
from dataclasses import dataclass, field
from typing import Generator


@dataclass
class Span:
    name: str
    trace_id: str
    span_id: str = field(default_factory=lambda: str(uuid.uuid4())[:8])
    start_time: float = field(default_factory=time.perf_counter)
    end_time: float | None = None
    metadata: dict = field(default_factory=dict)

    @property
    def duration_ms(self) -> float | None:
        if self.end_time is None:
            return None
        return (self.end_time - self.start_time) * 1000

    def finish(self) -> None:
        self.end_time = time.perf_counter()


class Tracer:
    """Lightweight in-process tracer. Replace with OpenTelemetry for production."""

    def __init__(self) -> None:
        self._spans: list[Span] = []

    def new_trace(self) -> str:
        return str(uuid.uuid4())[:12]

    @contextmanager
    def span(self, name: str, trace_id: str, **metadata) -> Generator[Span, None, None]:
        s = Span(name=name, trace_id=trace_id, metadata=metadata)
        self._spans.append(s)
        try:
            yield s
        finally:
            s.finish()

    def get_trace(self, trace_id: str) -> list[Span]:
        return [s for s in self._spans if s.trace_id == trace_id]

    def summary(self, trace_id: str) -> dict:
        spans = self.get_trace(trace_id)
        return {
            "trace_id": trace_id,
            "total_ms": sum(s.duration_ms or 0 for s in spans),
            "spans": [
                {"name": s.name, "duration_ms": s.duration_ms, **s.metadata}
                for s in spans
            ],
        }


tracer = Tracer()
