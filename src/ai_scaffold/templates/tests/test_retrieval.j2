"""Tests for the hybrid retriever and RAG pipeline."""
from __future__ import annotations

from unittest.mock import AsyncMock, MagicMock, patch

import pytest

from src.config import settings
from src.models import Document


@pytest.fixture
def mock_documents() -> list[Document]:
    return [
        Document(id="1", content="Test document content.", metadata={"source": "test"}),
        Document(id="2", content="Another test document.", metadata={"source": "test"}),
    ]


@pytest.mark.asyncio
async def test_retriever_returns_documents(mock_documents):
    with patch("src.components.hybrid_retriever.HybridRetriever.retrieve", new_callable=AsyncMock) as mock_retrieve:
        mock_retrieve.return_value = mock_documents
        from src.components.hybrid_retriever import HybridRetriever

        retriever = HybridRetriever()
        result = await retriever.retrieve("test query")
        assert len(result) > 0


@pytest.mark.asyncio
async def test_rag_pipeline_initialized():
    from src.services.rag_pipeline import RAGPipeline

    pipeline = RAGPipeline(settings)
    assert pipeline.settings is settings
