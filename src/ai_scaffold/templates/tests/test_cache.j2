"""Tests for the semantic cache."""
from __future__ import annotations

from unittest.mock import AsyncMock, patch

import pytest


@pytest.mark.asyncio
async def test_cache_miss_returns_none():
    with patch("src.services.semantic_cache.SemanticCache.get", new_callable=AsyncMock) as mock_get:
        mock_get.return_value = None
        from src.services.semantic_cache import SemanticCache

        cache = SemanticCache()
        result = await cache.get("query with no cache entry")
        assert result is None


@pytest.mark.asyncio
async def test_cache_set_and_get():
    with (
        patch("src.services.semantic_cache.SemanticCache.set", new_callable=AsyncMock),
        patch("src.services.semantic_cache.SemanticCache.get", new_callable=AsyncMock) as mock_get,
    ):
        mock_get.return_value = "cached answer"
        from src.services.semantic_cache import SemanticCache

        cache = SemanticCache()
        await cache.set("hello world", "cached answer")
        result = await cache.get("hello world")
        assert result == "cached answer"


@pytest.mark.asyncio
async def test_cache_invalidate():
    with patch("src.services.semantic_cache.SemanticCache.invalidate", new_callable=AsyncMock) as mock_inv:
        mock_inv.return_value = 1
        from src.services.semantic_cache import SemanticCache

        cache = SemanticCache()
        count = await cache.invalidate("test query")
        assert count == 1
