"""Tests for query routing and input validation."""
from __future__ import annotations

from unittest.mock import AsyncMock, patch

import pytest


@pytest.mark.asyncio
async def test_router_returns_valid_route():
    with patch("src.services.query_router.QueryRouter.route", new_callable=AsyncMock) as mock_route:
        mock_route.return_value = "rag"
        from src.services.query_router import QueryRouter

        router = QueryRouter()
        result = await router.route("What is in my documents?")
        assert result in QueryRouter.ROUTES


@pytest.mark.asyncio
async def test_input_guard_blocks_empty_query():
    from src.security.input_guard import InputGuard

    guard = InputGuard()
    with pytest.raises(ValueError):
        guard.validate("")


@pytest.mark.asyncio
async def test_input_guard_passes_valid_query():
    from src.security.input_guard import InputGuard

    guard = InputGuard()
    result = guard.validate("What is the capital of France?")
    assert result == "What is the capital of France?"
