"""Tests for query routing."""
from __future__ import annotations

from unittest.mock import AsyncMock, patch

import pytest


@pytest.mark.asyncio
async def test_router_returns_valid_route():
    from app.config import settings
    from app.services.query_router import QueryRouter, RouteTarget

    mock_llm = AsyncMock()
    mock_llm.ainvoke = AsyncMock(return_value=AsyncMock(content="rag"))

    with patch.object(QueryRouter, "_build_llm", return_value=mock_llm):
        router = QueryRouter(settings)
        router._llm = mock_llm
        result = await router.route("What is in my documents?")
        assert result == RouteTarget.RAG


@pytest.mark.asyncio
async def test_router_fallback_on_invalid_response():
    from app.config import settings
    from app.services.query_router import QueryRouter, RouteTarget

    mock_llm = AsyncMock()
    mock_llm.ainvoke = AsyncMock(return_value=AsyncMock(content="invalid_route"))

    with patch.object(QueryRouter, "_build_llm", return_value=mock_llm):
        router = QueryRouter(settings)
        router._llm = mock_llm
        result = await router.route("some query")
        assert result == RouteTarget.RAG  # defaults to RAG


@pytest.mark.asyncio
async def test_input_guard_blocks_empty_query():
    from fastapi import HTTPException
    from app.security.input_guard import InputGuard

    guard = InputGuard()
    with pytest.raises(HTTPException) as exc_info:
        guard.validate("")
    assert exc_info.value.status_code == 422


@pytest.mark.asyncio
async def test_input_guard_passes_valid_query():
    from app.security.input_guard import InputGuard

    guard = InputGuard()
    result = guard.validate("What is the capital of France?")
    assert result == "What is the capital of France?"
