[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "AI application scaffolded with create-ai-project"
readme = "README.md"
requires-python = ">={{ python_version }}"
{% if author_name %}
authors = [{ name = "{{ author_name }}"{% if author_email %}, email = "{{ author_email }}"{% endif %} }]
{% endif %}
dependencies = [
{%- for dep in extra_deps %}
  "{{ dep }}",
{%- endfor %}
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[dependency-groups]
dev = [
  "pytest>=8",
  "pytest-cov",
  "ruff",
  "mypy",
  "httpx>=0.27",
]

[tool.ruff.lint]
select = ["E", "F", "I", "UP"]

[tool.mypy]
strict = false
ignore_missing_imports = true

[tool.pytest.ini_options]
testpaths = ["tests"]
asyncio_mode = "auto"

[tool.ai-scaffold]
profile = "{{ profile }}"
llm_provider = "{{ llm_provider }}"
vector_db = "{{ vector_db }}"
embedding_model = "{{ embedding_model }}"
llm_model = "{{ llm_model }}"
scaffold_version = "{{ scaffold_version }}"
