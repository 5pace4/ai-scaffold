services:
  api:
    build: ./app
    ports:
      - "8000:8000"
    env_file: .env
    volumes:
      - ./data:/app/data
    depends_on:
{% if vector_db == "chroma" %}
      - chroma
{% elif vector_db == "qdrant" %}
      - qdrant
{% elif vector_db == "pgvector" %}
      - postgres
{% endif %}
    restart: unless-stopped

{% if include_frontend %}
  frontend:
    build: ./frontend
    ports:
      - "7860:7860"
    env_file: .env
    depends_on:
      - api
    restart: unless-stopped

{% endif %}
{% if vector_db == "chroma" %}
  chroma:
    image: chromadb/chroma:latest
    ports:
      - "8001:8000"
    volumes:
      - chroma_data:/chroma/chroma
    restart: unless-stopped

{% elif vector_db == "qdrant" %}
  qdrant:
    image: qdrant/qdrant:latest
    ports:
      - "6333:6333"
    volumes:
      - qdrant_data:/qdrant/storage
    restart: unless-stopped

{% elif vector_db == "pgvector" %}
  postgres:
    image: pgvector/pgvector:pg16
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: {{ package_name }}
    ports:
      - "5432:5432"
    volumes:
      - pg_data:/var/lib/postgresql/data
    restart: unless-stopped

{% endif %}
volumes:
{% if vector_db == "chroma" %}
  chroma_data:
{% elif vector_db == "qdrant" %}
  qdrant_data:
{% elif vector_db == "pgvector" %}
  pg_data:
{% endif %}
